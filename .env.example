# Runtime
# Streamlit UI reads GEOLLM_API_URL from docker-compose; override only for non-Compose deployments.
GEOLLM_API_URL=http://geollm-api:8080
STREAMLIT_API_TIMEOUT_SECONDS=900
APP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8080

# Agent/LLM. Default mock mode keeps local smoke tests keyless.
GEO_LLM_PROVIDER=mock
GEO_LLM_MODEL=mock-geoplanner
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-geoprocessing-prod

# PostGIS / checkpointing / artifacts
POSTGIS_ENABLED=true
POSTGIS_HOST=postgis
POSTGIS_PORT=5432
POSTGIS_DB=geollm
POSTGIS_USER=geollm
POSTGIS_PASSWORD=change-me-in-prod
POSTGIS_SCHEMA=public
CHECKPOINT_BACKEND=memory
ARTIFACT_BASE_DIR=/gee_out

# GEE plugin service
GEE_PLUGIN_URL=http://gee-plugin-api:8000
GEE_REAL_EXECUTION=false
GEE_MAX_TILES_DEFAULT=16
GEE_MAX_TILES_HARD_LIMIT=128
EE_PRIVATE_KEY_PATH=/run/secrets/gee_sa_json

# API safety budgets
REQUEST_TIMEOUT_SECONDS=60
TOOL_TIMEOUT_SECONDS=600
MAX_BBOX_AREA_DEGREES=25
MAX_RUN_ACTIONS=8

# Docker service credentials
POSTGRES_DB=geollm
POSTGRES_USER=geollm
POSTGRES_PASSWORD=change-me-in-prod
